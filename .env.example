# =========================
# APP
# =========================
NODE_ENV=development
APP_NAME=my-app

# =========================
# PORTS EXPOSED TO HOST
# These are the ports you map in docker-compose
# =========================
FRONTEND_PORT=5173
BACKEND_PORT=4000
POSTGRES_PORT=5432

# =========================
# FRONTEND
# Public URL used in browser
# =========================
FRONTEND_URL=http://localhost:5173

# API URL the frontend uses from the browser
# Since browser calls go through the host-mapped port,
# use localhost here, not the Docker service name.
VITE_API_URL=http://localhost:4000/api

# If not using Vite, keep one of these only if needed
NEXT_PUBLIC_API_URL=http://localhost:4000/api
PUBLIC_API_URL=http://localhost:4000/api

# =========================
# BACKEND
# Inside Docker, backend should bind to all interfaces
# =========================
BACKEND_HOST=0.0.0.0
BACKEND_URL=http://localhost:4000
API_PREFIX=/api

# =========================
# DATABASE (PostgreSQL service)
# IMPORTANT:
# DB_HOST should be the docker-compose service name
# =========================
DB_CLIENT=postgres
DB_HOST=database
DB_PORT=5432
DB_NAME=my_app_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_SYNCHRONIZE=true
DB_DROP_SCHEMA=false

# For libraries/ORMs that prefer a single connection string
DATABASE_URL=postgresql://postgres:postgres@database:5432/my_app_db

# =========================
# POSTGRES CONTAINER DEFAULTS
# Used by the postgres image itself
# =========================
POSTGRES_DB=my_app_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# =========================
# AUTH - JWT ONLY
# Stateless auth, no refresh tokens
# =========================
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d
JWT_ISSUER=my-app
JWT_AUDIENCE=my-app-users
AUTH_ALLOW_PUBLIC_REGISTRATION=false
SYSADMIN_USERNAME=admin
SYSADMIN_PASSWORD=change_me_admin_password

# =========================
# PASSPORT
# For passport-jwt, not passport session
# =========================
PASSPORT_SESSION_ENABLED=false

# =========================
# PASSWORD HASHING
# =========================
BCRYPT_SALT_ROUNDS=12

# =========================
# CORS
# Browser origin allowed to call backend
# =========================
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=false

# =========================
# LOGGING
# =========================
LOG_LEVEL=debug

# =========================
# OPTIONAL SECURITY / RATE LIMIT
# =========================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
TRUST_PROXY=false
